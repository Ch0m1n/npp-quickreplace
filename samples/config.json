{
  "pluginEnabled": true,
  "rememberEnabledState": true,
  "punctuationTriggers": ".,:;!?)]}",
  "processPaste": false,
  "skipReadOnlyDocuments": true,
  "skipMultiSelection": false,
  "backup": {
    "enabled": true,
    "maxFiles": 10
  },
  "maxTriggerBytes": 512,
  "maxExpandedBytes": 1048576,
  "logging": {
    "enabled": false,
    "level": "warning"
  }
}

