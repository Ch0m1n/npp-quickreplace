#include <windows.h>
#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 0,5,0,0
 PRODUCTVERSION 0,5,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_DLL
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "NppQuickReplace contributors\0"
            VALUE "FileDescription", "Fast, local text expansion for Notepad++\0"
            VALUE "FileVersion", "0.5.0-alpha\0"
            VALUE "InternalName", "NppQuickReplace\0"
            VALUE "LegalCopyright", "Copyright (C) 2026 NppQuickReplace contributors\0"
            VALUE "OriginalFilename", "NppQuickReplace.dll\0"
            VALUE "ProductName", "NppQuickReplace\0"
            VALUE "ProductVersion", "0.5.0-alpha\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

